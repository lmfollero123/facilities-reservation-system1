APP_ENV=local

# Captcha (Cloudflare Turnstile) - free anti-spam
# 1) Create keys at https://dash.cloudflare.com/turnstile
# 2) Add hostnames on the widget: cprf.infragovservices.com (prod) AND lgu.test / localhost (local)
# 3) Local-only test keys (always pass): site 1x00000000000000000000AA / secret 1x00000000000000000000AA
# Production: prefer ~/private/cprf.env (overrides .env on cPanel)
CAPTCHA_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Database
DB_HOST=localhost
DB_NAME=facilities_reservation
DB_USER=root
DB_PASS=

# Mail / SMTP
MAIL_SMTP_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=LGU Facilities
# Optional anti-spam mail guard (limits outbound SMTP)
MAIL_RATE_LIMIT_GLOBAL_MAX=80
MAIL_RATE_LIMIT_GLOBAL_WINDOW=600
MAIL_RATE_LIMIT_PER_RECIPIENT_MAX=5
MAIL_RATE_LIMIT_PER_RECIPIENT_WINDOW=600
MAIL_RATE_LIMIT_PER_IP_MAX=20
MAIL_RATE_LIMIT_PER_IP_WINDOW=600

# Booking reminders (cron: scripts/send_booking_reminders.php)
BOOKING_REMINDER_HOURS_BEFORE=24

# Gemini AI
GEMINI_API_KEY=

# Geocoding providers (optional)
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# CIMM maintenance integration (optional)
CIMM_API_KEY=
# Keys shared with CIMM for two-way integration (must match CIMM server config)
FACILITIES_API_KEY=FACILITIES_SECURE_KEY_2025
LGU_WEBHOOK_KEY=LGU_TO_FACILITIES_KEY_2025

# UMAN utilities management integration (optional)
UMAN_API_URL=https://uman.infragovservices.com
UMAN_API_KEY=UMAN_SECURE_KEY_2025

# SMS (IPROG) — https://www.iprogsms.com/api/v1/documentation
SMS_ENABLED=true
SMS_DRIVER=iprogsms
SMS_DEFAULT_RECIPIENT=
IPROG_API_TOKEN=
IPROG_ENDPOINT=https://www.iprogsms.com/api/v1/sms_messages
# Other drivers: log | email_gateway | philsms (legacy)
# --- Email-to-SMS gateway (free via your Gmail SMTP; best for Globe/TM) ---
# SMS_DRIVER=email_gateway
# SMS_EMAIL_GLOBE_DOMAIN=messaging.globe.com.ph
# SMS_EMAIL_SMART_DOMAIN=messaging.smart.com.ph
# SMS_EMAIL_DEFAULT_NETWORK=globe
# SMS_EMAIL_SUBJECT=SMS
# --- Demo log only (no real SMS) ---
# SMS_DRIVER=log
# SMS_LOG_PATH=

# Application URL (required for PayMongo redirect URLs in production)
APP_URL=https://cprf.infragovservices.com

# Payments
PAYMENTS_ENABLED=true
REQUIRE_PAYMENT_FOR_RESERVATIONS=true
PAYMENT_WINDOW_MINUTES=60
PAYMENT_CURRENCY=PHP
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_API_VERSION=v2
PAYMONGO_LINKS_ENDPOINT=https://api.paymongo.com/v1/links
PAYMONGO_DESCRIPTION_PREFIX=LGU Culiat Reservation
