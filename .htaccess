# Security Headers and Protections
# Apache / OpenLiteSpeed configuration for Facilities Reservation System

# ---------------------------------------------------------------------------
# BLOCK SENSITIVE FILES FIRST (before any rewrite-to-index.php logic)
# OpenLiteSpeed/CyberPanel may ignore FilesMatch/Require but still honor RewriteRule.
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Dotenv and env backups — highest priority
    RewriteRule (^|/)\.env(\.|$) - [F,L]
    RewriteRule (^|/)env\.(local|production|backup|example)$ - [F,L,NC]

    # Sensitive directories (URL path, not filesystem)
    RewriteRule ^(config|database|storage|logs|scripts|vendor|tests|ai|\.git)(/|$) - [F,L]

    # Sensitive root files
    RewriteRule ^(composer\.(json|lock)|phpunit\.xml|\.gitignore|\.env\.example)$ - [F,L,NC]

    # Block debug/test scripts that must not run on production
    RewriteRule ^(clear_cache|test_[^/]+)\.php$ - [F,L,NC]

    # Route remaining requests to index.php for URL-based routing
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [L]

    # Force HTTPS in production (uncomment when deploying with SSL certificate)
    # RewriteCond %{HTTPS} off
    # RewriteCond %{HTTP_HOST} !^localhost [NC]
    # RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Set default index files (adjust if needed)
DirectoryIndex index.php index.html

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://static.cloudflareinsights.com https://challenges.cloudflare.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://fonts.gstatic.com https://unpkg.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; frame-src 'self' https://www.google.com https://maps.google.com https://challenges.cloudflare.com; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://cloudflareinsights.com https://challenges.cloudflare.com https://unpkg.com;"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# Explicit deny for .env (Apache 2.4)
<Files ".env">
    Require all denied
</Files>
<Files ".env.local">
    Require all denied
</Files>
<Files ".env.production">
    Require all denied
</Files>
<Files ".env.backup">
    Require all denied
</Files>

# Apache 2.2 / legacy fallback
<IfModule !mod_authz_core.c>
    <Files ".env">
        Order allow,deny
        Deny from all
    </Files>
    <Files ".env.local">
        Order allow,deny
        Deny from all
    </Files>
</IfModule>

# Protect sensitive extensions (narrow — do not block public css/js)
<FilesMatch "\.(sql|log|ini|conf|env|bak)$">
    Require all denied
</FilesMatch>

# Protect hidden files (except .well-known for SSL)
<FilesMatch "^\.(?!well-known)">
    Require all denied
</FilesMatch>

# Disable directory browsing
Options -Indexes

# Character encoding
AddDefaultCharset UTF-8

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/json "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpe?g|gif|webp|svg|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
